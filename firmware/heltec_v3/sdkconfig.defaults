# ESP-IDF defaults for uReticulum on Heltec V3.
# These get baked into sdkconfig on first idf.py build.

CONFIG_IDF_TARGET="esp32s3"

# Enable C++ exceptions — uReticulum throws on a few error paths.
CONFIG_COMPILER_CXX_EXCEPTIONS=y
CONFIG_COMPILER_CXX_EXCEPTIONS_EMG_POOL_SIZE=0

# Heltec V3 has a CP2102 USB-UART bridge wired to UART0 — not native
# ESP32-S3 USB CDC. Use default UART console so the CP2102 carries logs.
CONFIG_ESP_CONSOLE_UART_DEFAULT=y

# FreeRTOS config — recursive mutexes are used by Transport.
CONFIG_FREERTOS_USE_TIMERS=y
CONFIG_FREERTOS_HZ=1000

# Runtime statistics — needed so we can ask FreeRTOS how much time each
# task has spent running. Used by the firmware to display CPU idle %.
CONFIG_FREERTOS_USE_TRACE_FACILITY=y
CONFIG_FREERTOS_GENERATE_RUN_TIME_STATS=y
CONFIG_FREERTOS_USE_STATS_FORMATTING_FUNCTIONS=y

# Stack and task tuning. Reticulum loop is spawned with 8192 words of
# stack from app_main; the main task itself doesn't need to be huge.
CONFIG_ESP_MAIN_TASK_STACK_SIZE=8192

# Enable mbedTLS algorithms uReticulum needs (these are usually on by
# default but listed for clarity).
CONFIG_MBEDTLS_HARDWARE_AES=y
CONFIG_MBEDTLS_HARDWARE_SHA=y
CONFIG_MBEDTLS_HKDF_C=y

# Optimisation: -Os keeps flash usage down, OK for our workload.
CONFIG_COMPILER_OPTIMIZATION_SIZE=y

# Power management — dynamic frequency scaling + tickless idle lets the
# MCU drop to light sleep between DIO1 / timer interrupts. On top of the
# already-~99% WFI idle we see without PM, this should cut the MCU's
# contribution to total power by another ~50%.
CONFIG_PM_ENABLE=y
CONFIG_PM_DFS_INIT_AUTO=y
CONFIG_FREERTOS_USE_TICKLESS_IDLE=y
CONFIG_FREERTOS_IDLE_TIME_BEFORE_SLEEP=3

# Allow the MCU to scale all the way down when idle. Max freq is bound
# by the CPU clock we selected; min is 10 MHz; light sleep is entered
# whenever both are OK.
CONFIG_ESP_DEFAULT_CPU_FREQ_MHZ_160=y

# Heltec V3 has 8MB flash (W25Q64). The default 2MB autodetect is
# wrong and too small for OTA dual-slot partitions.
CONFIG_ESPTOOLPY_FLASHSIZE_8MB=y
CONFIG_ESPTOOLPY_FLASHSIZE="8MB"

# Custom partition table with two OTA slots (~1.75MB each).
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions.csv"

# OTA rollback: if new firmware doesn't mark itself valid within 30s
# the bootloader reverts to the previous slot.
CONFIG_BOOTLOADER_APP_ROLLBACK_ENABLE=y

# Allow OTA over plain HTTP (no TLS) for LAN update servers.
CONFIG_ESP_HTTPS_OTA_ALLOW_HTTP=y

# WiFi + TCP defaults are empty — configure via menuconfig or NVS.
CONFIG_WIFI_DEFAULT_SSID=""
CONFIG_WIFI_DEFAULT_PSK=""
CONFIG_TCP_INTERFACE_HOST=""
CONFIG_TCP_INTERFACE_PORT=4965
