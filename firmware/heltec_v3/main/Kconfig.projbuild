menu "RTReticulum Heltec V3"

    choice HELTEC_V3_MODE
        prompt "Firmware operating mode"
        default HELTEC_V3_MODE_TRANSPORT
        help
            Select whether this board runs as a standalone Reticulum
            transport node (default) or as a host-attached RNode bridge
            that Python Reticulum drives over USB serial.

        config HELTEC_V3_MODE_TRANSPORT
            bool "Transport node (autonomous)"
            help
                Boots into RTReticulum with its own Identity, announces a
                local destination, and opens Links to peers over LoRa.

        config HELTEC_V3_MODE_RNODE
            bool "RNode bridge over USB UART"
            help
                Exposes the SX1262 to a USB host via the RNode KISS
                serial protocol so Python RNS (nomadnet, rnsd, etc.)
                can drive it as an rnode interface. The RTReticulum stack
                is not started in this mode; the board is a dumb radio.

        config HELTEC_V3_MODE_RNODE_BLE
            bool "RNode bridge over Bluetooth LE"
            help
                Same KISS bridge as the UART variant, but wrapped in a
                Nordic UART Service GATT profile so Python RNS can
                connect over BLE with `port = ble://RNode XXXX`. Useful
                for driving the radio from a phone or tablet. Pulls in
                NimBLE and adds ~300 KB to the firmware image.

    endchoice

endmenu

menu "RTReticulum LoRa"

    config LORA_FREQ_MHZ_X10
        int "Frequency (MHz x10, e.g. 9150 = 915.0 MHz)"
        default 9150
        help
            LoRa center frequency in tenths of MHz. Multiply your desired
            frequency by 10: 915.0 MHz = 9150, 868.0 MHz = 8680,
            433.0 MHz = 4330. Tenths allow sub-MHz precision without
            floating point in Kconfig.

    config LORA_BANDWIDTH_KHZ
        int "Bandwidth (kHz)"
        default 125
        range 8 500
        help
            LoRa bandwidth in kHz. Common values: 125, 250, 500.
            Must match the peer's bandwidth.

    config LORA_SPREADING_FACTOR
        int "Spreading factor"
        default 9
        range 5 12
        help
            LoRa spreading factor (5-12). Higher SF = longer range but
            slower. SF9 is a good default for Reticulum on 915 MHz.

    config LORA_CODING_RATE
        int "Coding rate"
        default 7
        range 5 8
        help
            LoRa coding rate (5-8). Higher = more error correction but
            slower. 7 matches upstream RNode defaults.

    config LORA_TX_POWER_DBM
        int "TX power (dBm)"
        default 14
        range 2 22
        help
            Transmit power in dBm. SX1262 supports 2-22 dBm.
            14 dBm is a reasonable default for short-range testing.

    config LORA_PREAMBLE_LENGTH
        int "Preamble length (symbols)"
        default 8
        range 4 65535
        help
            LoRa preamble length in symbols. 8 is the standard default.

endmenu

menu "RTReticulum WiFi + OTA"

    config WIFI_DEFAULT_SSID
        string "Default WiFi SSID"
        default ""
        help
            WiFi AP to connect to in STA mode. Leave empty to disable
            WiFi. Can be overridden at runtime via NVS.

    config WIFI_DEFAULT_PSK
        string "Default WiFi PSK"
        default ""
        help
            WiFi password. Can be overridden at runtime via NVS.

    config TCP_INTERFACE_HOST
        string "Reticulum TCP peer host"
        default ""
        help
            Hostname or IP of an upstream Reticulum node (rnsd) to
            connect to over WiFi. Leave empty to disable the TCP
            interface. The transport node will bridge LoRa ↔ TCP.

    config TCP_INTERFACE_PORT
        int "Reticulum TCP peer port"
        default 4965
        help
            TCP port of the upstream Reticulum node.

    config OTA_DEFAULT_URL
        string "Default OTA firmware URL"
        default ""
        help
            HTTP URL to pull firmware from on OTA update. Example:
            http://192.168.1.100:8080/rtreticulum.bin

endmenu
